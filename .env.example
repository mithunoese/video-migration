# ==============================
# Kaltura Configuration
# ==============================
# Get these from Kaltura KMC admin console
# Requires Publisher Administrator access
KALTURA_PARTNER_ID=
KALTURA_ADMIN_SECRET=
KALTURA_USER_ID=
KALTURA_SERVICE_URL=https://www.kaltura.com

# ==============================
# AWS Configuration
# ==============================
# Standard AWS credentials (via env vars, ~/.aws/credentials, or IAM role)
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_STAGING_PREFIX=migration-staging/
AWS_STATE_TABLE=video-migration-state

# ==============================
# Zoom Configuration
# ==============================
# Create a Server-to-Server OAuth app in Zoom Marketplace
# https://marketplace.zoom.us/develop/create
# Required scopes: clips:write (upload+manage), clips:read (read metadata)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
# All uploads go through Zoom Clips API (the only Zoom API with upload support).
# This label is for tracking only: "clips" (default), "events", "vm"
ZOOM_TARGET_API=clips

# ==============================
# Pipeline Configuration
# ==============================
BATCH_SIZE=10
MAX_CONCURRENCY=5
RETRY_ATTEMPTS=3
RETRY_DELAY=5
DOWNLOAD_DIR=/tmp/video-migration
LOG_LEVEL=INFO

# ==============================
# AI Assistant (Optional)
# ==============================
# For advanced AI features in the dashboard chat
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ==============================
# Security Configuration
# ==============================
# JWT secret key for dashboard authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_EXPIRATION_HOURS=24

# Dashboard admin credentials
# Default: admin/admin — CHANGE IN PRODUCTION
ADMIN_USER=admin
# Generate hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# ==============================
# Production Security (Optional)
# ==============================
# Set to "production" to enable HSTS headers
ENVIRONMENT=development
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# State directory for migration data and cost tracking
# Default: ~/.video-migration (local) or /app/data (Docker)
STATE_DIR=

# Docker dashboard port
DASHBOARD_PORT=8000
